{
  "name": "@translation-platform/sdk-react",
  "version": "1.1.0",
  "private": true,
  "description": "React/Next.js SDK for the centralized Translation Platform: stale-while-revalidate bundles, batched key auto-registration, interpolation, and SSR-safe hooks.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepare": "tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "typescript": "^5.4.5"
  }
}
